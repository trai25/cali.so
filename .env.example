# Postgres runtime role: CRUD only, never schema ownership or DDL grants
DATABASE_URL=

# Drizzle commands require MIGRATION_DATABASE_URL only in that command's
# environment. Never put the migration credential in this runtime file or Vercel.

# Clerk owner authentication. Authorize the owner by setting the Clerk user's
# public metadata to { "siteOwner": "yes" } in the Clerk Dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Durable owner data namespace and Google Calendar owner. ADMIN_EMAIL does not
# grant admin access, but it must not change without migrating owner-scoped data.
ADMIN_EMAIL=
AMA_ENCRYPTION_KEY=
RATE_LIMIT_HASH_KEY=
# Public discovery identity for canonical links, feeds, and social metadata.
# Replace both origins with your deployment domain.
PUBLIC_SITE_URL=https://your-domain.com
# Operational origin for links, provider callbacks, and browser mutations.
# Custom environments use their stable alias, such as https://beta.cali.so.
SITE_URL=https://your-domain.com
CRON_SECRET=

# Google Calendar OAuth (owner availability + meeting invitations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production-only Upstash (authenticated admin mutations and Media Alt Text
# Suggestions). Preview uses its isolated Neon database; Local and CI use
# process-local limits. Configure one complete pair in Production only:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel Marketplace aliases are accepted instead of the native pair:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
ADMIN_MUTATION_RATE_LIMIT_MAX_REQUESTS=30
ADMIN_MUTATION_RATE_LIMIT_WINDOW_SECONDS=60

# AMA capabilities are enabled by default. Each provider capability turns on
# when its credential pair below is configured, and its routes fail closed
# with 503 while the pair is blank. Pairs must be complete or empty.

# Stripe-hosted Checkout for AMA Bookings. The webhook secret signs
# /api/ama/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Transactional AMA email through Resend. AMA_EMAIL_FROM accepts
# "Name <address@domain>".
RESEND_API_KEY=
AMA_EMAIL_FROM=

# Tencent Meeting MCP bridge (server-only URL and token).
TENCENT_MEETING_MCP_URL=
TENCENT_MEETING_MCP_TOKEN=

# Public AMA booking mutations are rate limited per client.
AMA_PUBLIC_RATE_LIMIT_MAX_REQUESTS=10
AMA_PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60

# Bunny Media Library. Originals, Renditions, and transfer chunks share one
# public Storage Zone and Pull Zone. Preview uses non-production credentials.
BUNNY_MEDIA_REGION=sg
BUNNY_MEDIA_ZONE=
BUNNY_MEDIA_PASSWORD=
BUNNY_MEDIA_CDN_URL=
BUNNY_CDN_API_KEY=
MEDIA_ENCRYPTION_KEY=

# Owner-requested Capture Location to Location Label suggestions. The provider
# is available whenever its server-restricted credential is configured.
GOOGLE_MAPS_GEOCODING_API_KEY=

# Media Library Alt Text Suggestions use Vercel OIDC in deployed environments.
# The capability is enabled by default and has no runtime feature switch.
MEDIA_ALT_TEXT_PRIMARY_MODEL=openai/gpt-5.6-luna
MEDIA_ALT_TEXT_FALLBACK_MODEL=openai/gpt-5.4-mini
MEDIA_ALT_TEXT_TIMEOUT_MS=12000
MEDIA_ALT_TEXT_MAX_RETRIES=1
MEDIA_ALT_TEXT_RATE_LIMIT_MAX_REQUESTS=10
MEDIA_ALT_TEXT_RATE_LIMIT_WINDOW_SECONDS=3600

# Used only by the opt-in non-production storage contract. Do not set the
# confirmation flag in a deployed runtime environment.
BUNNY_STORAGE_CONTRACT_ENVIRONMENT=non-production
BUNNY_STORAGE_CONTRACT_ORIGIN=https://cali.so
BUNNY_STORAGE_CONTRACT_EDGE_TTL_SECONDS=
BUNNY_STORAGE_CONTRACT_BROWSER_TTL_SECONDS=
# BUNNY_STORAGE_LIVE_TEST=confirmed-non-production
