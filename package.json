    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@js-temporal/polyfill": "^0.5.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tabler/icons-react": "^3.44.0",
    "@untitledui/icons": "^0.0.22",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.7.5",
    "ai": "^6.0.226",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cuelume": "0.1.0",
    "drizzle-orm": "^0.45.2",
    "exifr": "^7.1.3",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "heic-decode": "^2.1.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.3.0-preview.6",
    "next-mdx-remote": "^6.0.0",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rss": "^1.2.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "shaders": "3.0.440",
    "sharp": "^0.34.5",
    "shiki": "^4.3.1",
    "subset-font": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@next/playwright": "16.3.0-preview.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/rss": "^0.0.32",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
